# Mneme Cloud Server configuration
# Copy to /etc/mneme/cloud.env (systemd) or .env (docker-compose) and fill in.

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Format: postgres://user:password@host:5432/dbname?sslmode=disable
MNEME_DSN=

# JWT signing secret for API authentication.
# Generate with: openssl rand -hex 32
MNEME_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────

# HTTP port (default: 7438)
MNEME_PORT=7438
